{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "packageRules": [
    {
      "description": "Docker images (non-major)",
      "matchDatasources": ["docker"],
      "automerge": true,
      "matchUpdateTypes": ["minor", "patch"]
    },
    {
      "description": "Docker images (major)",
      "matchDatasources": ["docker"],
      "automerge": false,
      "matchUpdateTypes": ["major"]
    }
  ]
}
