{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommitTypeAll(chore)",
    "group:allNonMajor",
    ":automergeMinor",
    ":automergePatch",
    "security:openssf-scorecard",
    "github>traPtitech/portal-oidc//.github/renovate/commit-message.json5",
    "github>traPtitech/portal-oidc//.github/renovate/labels.json5",
  ],
  "timezone": "Asia/Tokyo",
  "prHourlyLimit": 5,
  "prConcurrentLimit": 10,
  "vulnerabilityAlerts": {
    "enabled": true,
  },
  "packageRules": [
    {
      "description": "Group Go security updates (non-major)",
      "matchManagers": ["gomod"],
      "automerge": true,
      "automergeType": "pr",
      "isVulnerabilityAlert": true,
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "go security updates"
    },
    {
      "description": "Go dependencies",
      "matchManagers": ["gomod"],
      "automerge": true,
      "automergeType": "pr",
      "matchUpdateTypes": ["minor", "patch"]
    },
    {
      "description": "Go major updates",
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["major"],
      "automerge": false
    },
    {
      "description": "Docker Compose images",
      "matchManagers": ["docker-compose"],
      "automerge": true,
      "automergeType": "pr",
      "matchUpdateTypes": ["minor", "patch"]
    },
    {
      "description": "Docker Compose major updates",
      "matchManagers": ["docker-compose"],
      "matchUpdateTypes": ["major"],
      "automerge": false
    },
    {
      "description": "mise tool versions",
      "matchManagers": ["mise"],
      "automerge": true,
      "automergeType": "pr",
      "matchUpdateTypes": ["minor", "patch"]
    },
    {
      "description": "mise major updates",
      "matchManagers": ["mise"],
      "matchUpdateTypes": ["major"],
      "automerge": false
    },
    {
      "description": "GitHub Actions",
      "matchManagers": ["github-actions"],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Group test dependencies",
      "matchPackagePatterns": ["^github.com/stretchr/testify"],
      "groupName": "test dependencies"
    }
  ]
}
