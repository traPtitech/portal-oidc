{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommitTypeAll(chore)",
    "group:allNonMajor",
    ":automergeMinor",
    ":automergePatch",
    "security:openssf-scorecard",
    "github>traPtitech/portal-oidc//.github/renovate/gomod.json5",
    "github>traPtitech/portal-oidc//.github/renovate/mise.json5",
    "github>traPtitech/portal-oidc//.github/renovate/docker.json5",
    "github>traPtitech/portal-oidc//.github/renovate/github-actions.json5",
    "github>traPtitech/portal-oidc//.github/renovate/commit-message.json5",
    "github>traPtitech/portal-oidc//.github/renovate/labels.json5",
  ],
  "timezone": "Asia/Tokyo",
  "prHourlyLimit": 5,
  "prConcurrentLimit": 10,
  "vulnerabilityAlerts": {
    "enabled": true,
  },
}
